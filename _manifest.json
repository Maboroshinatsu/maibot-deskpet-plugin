{
  "manifest_version": 2,
  "id": "maibot.deskpet-plugin",
  "version": "0.1.0",
  "name": "桌面宠物插件 (Live2D Deskpet)",
  "description": "为 MaiBot 提供 Live2D 桌面宠物交互能力，包括双向对话、表情控制、动作触发等。需要在桌面端运行 deskpet-app Electron 应用。",
  "author": {
    "name": "MaiBot Deskpet",
    "url": "https://github.com"
  },
  "license": "MIT",
  "urls": {
    "repository": "https://github.com",
    "homepage": "https://github.com"
  },
  "host_application": {
    "min_version": "1.0.0",
    "max_version": "1.99.99"
  },
  "sdk": {
    "min_version": "2.0.0",
    "max_version": "2.99.99"
  },
  "dependencies": [
    {
      "type": "python_package",
      "name": "websockets",
      "version_spec": ">=12.0"
    }
  ],
  "capabilities": [],
  "i18n": {
    "default_locale": "zh-CN",
    "supported_locales": ["zh-CN"]
  }
}
