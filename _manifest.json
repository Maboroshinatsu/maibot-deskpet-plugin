{
  "manifest_version": 2,
  "id": "maibot.deskpet-plugin",
  "version": "0.1.0",
  "name": "MaiVTB",
  "description": "为 MaiBot 接入 Live2D 桌面宠物，支持双向对话（消息管线集成）、表情/动作控制、视线追踪、滚轮缩放和拖拽平移。需配合 deskpet-app Electron 前端使用。",
  "author": {
    "name": "MaboroshiNatsu / DeepSeek-V4PRO",
    "url": "https://github.com/Maboroshinatsu"
  },
  "license": "GPL-3.0",
  "urls": {
    "repository": "https://github.com/Maboroshinatsu/maibot-deskpet-plugin",
    "homepage": "https://github.com/Maboroshinatsu/maibot-deskpet-plugin"
  },
  "host_application": {
    "min_version": "1.0.0",
    "max_version": "1.99.99"
  },
  "sdk": {
    "min_version": "2.0.0",
    "max_version": "2.99.99"
  },
  "dependencies": [
    {
      "type": "python_package",
      "name": "websockets",
      "version_spec": ">=12.0"
    }
  ],
  "capabilities": [],
  "i18n": {
    "default_locale": "zh-CN",
    "supported_locales": ["zh-CN"]
  }
}
