{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "composite": true,
    "noEmit": false,
    "outDir": "./out"
  },
  "include": ["electron-vite.config.ts", "src/main/**/*.ts", "src/preload/**/*.ts"]
}
